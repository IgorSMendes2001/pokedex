{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": ["jest"],
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "bundler",
    "module": "esnext"
  },
  "include": ["src/**/*.spec.ts", "src/**/*.d.ts", "src/**/*.ts"]
}
